#! /usr/bin/vvp
:ivl_version "12.0 (stable)";
:ivl_delay_selection "TYPICAL";
:vpi_time_precision - 12;
:vpi_module "/usr/lib/x86_64-linux-gnu/ivl/system.vpi";
:vpi_module "/usr/lib/x86_64-linux-gnu/ivl/vhdl_sys.vpi";
:vpi_module "/usr/lib/x86_64-linux-gnu/ivl/vhdl_textio.vpi";
:vpi_module "/usr/lib/x86_64-linux-gnu/ivl/v2005_math.vpi";
:vpi_module "/usr/lib/x86_64-linux-gnu/ivl/va_math.vpi";
S_0x5e1d25801b80 .scope module, "tb_mux" "tb_mux" 2 3;
 .timescale -9 -12;
v0x5e1d258157c0_0 .var "a", 31 0;
v0x5e1d258158a0_0 .var "b", 31 0;
v0x5e1d25815970_0 .var "sel", 0 0;
v0x5e1d25815a70_0 .net "y", 31 0, L_0x5e1d25815b40;  1 drivers
S_0x5e1d25801d10 .scope module, "uut" "mux" 2 9, 3 1 0, S_0x5e1d25801b80;
 .timescale 0 0;
    .port_info 0 /INPUT 32 "a";
    .port_info 1 /INPUT 32 "b";
    .port_info 2 /INPUT 1 "sel";
    .port_info 3 /OUTPUT 32 "y";
v0x5e1d25801f60_0 .net "a", 31 0, v0x5e1d258157c0_0;  1 drivers
v0x5e1d258154b0_0 .net "b", 31 0, v0x5e1d258158a0_0;  1 drivers
v0x5e1d25815590_0 .net "sel", 0 0, v0x5e1d25815970_0;  1 drivers
v0x5e1d25815630_0 .net "y", 31 0, L_0x5e1d25815b40;  alias, 1 drivers
L_0x5e1d25815b40 .functor MUXZ 32, v0x5e1d258157c0_0, v0x5e1d258158a0_0, v0x5e1d25815970_0, C4<>;
    .scope S_0x5e1d25801b80;
T_0 ;
    %vpi_call 2 17 "$dumpfile", "dump.vcd" {0 0 0};
    %vpi_call 2 18 "$dumpvars", 32'sb00000000000000000000000000000000, S_0x5e1d25801b80 {0 0 0};
    %pushi/vec4 2863311530, 0, 32;
    %store/vec4 v0x5e1d258157c0_0, 0, 32;
    %pushi/vec4 1431655765, 0, 32;
    %store/vec4 v0x5e1d258158a0_0, 0, 32;
    %pushi/vec4 0, 0, 1;
    %store/vec4 v0x5e1d25815970_0, 0, 1;
    %delay 10000, 0;
    %pushi/vec4 1, 0, 1;
    %store/vec4 v0x5e1d25815970_0, 0, 1;
    %delay 10000, 0;
    %pushi/vec4 305419896, 0, 32;
    %store/vec4 v0x5e1d258157c0_0, 0, 32;
    %pushi/vec4 2271560481, 0, 32;
    %store/vec4 v0x5e1d258158a0_0, 0, 32;
    %pushi/vec4 0, 0, 1;
    %store/vec4 v0x5e1d25815970_0, 0, 1;
    %delay 10000, 0;
    %pushi/vec4 1, 0, 1;
    %store/vec4 v0x5e1d25815970_0, 0, 1;
    %delay 10000, 0;
    %vpi_call 2 40 "$finish" {0 0 0};
    %end;
    .thread T_0;
    .scope S_0x5e1d25801b80;
T_1 ;
    %vpi_call 2 44 "$monitor", "Time=%0t | sel=%b | a=%h | b=%h | y=%h", $time, v0x5e1d25815970_0, v0x5e1d258157c0_0, v0x5e1d258158a0_0, v0x5e1d25815a70_0 {0 0 0};
    %end;
    .thread T_1;
